{
  "name": "sandybridge-app-template",
  "version": "2.0.0",
  "variables": {
    "project_name": {
      "description": "Name of the project",
      "required": true
    }
  },
  "features": {
    "docs": {
      "description": "Include MDX documentation system",
      "default": false,
      "files": [
        "src/routes/docs/**/*",
        "content/docs/**/*",
        "src/lib/docs.ts",
        "src/lib/mdx-components.tsx",
        "src/components/docs-sidebar.tsx",
        "src/components/copyable-pre.tsx"
      ],
      "dependencies": {
        "@mdx-js/react": "^3.1.0",
        "gray-matter": "^4.0.3"
      },
      "devDependencies": {
        "@mdx-js/rollup": "^3.1.0",
        "remark-frontmatter": "^5.0.0",
        "remark-mdx-frontmatter": "^5.0.0"
      }
    },
    "auth": {
      "description": "Include Auth.js authentication",
      "default": true,
      "files": [
        "src/lib/auth.ts",
        "src/components/session-provider.tsx",
        "api/auth/**/*"
      ],
      "dependencies": {
        "@auth/core": "^0.37.4"
      }
    },
    "db": {
      "description": "Include PostgreSQL database setup",
      "default": false,
      "files": [
        "src/lib/db.ts"
      ],
      "dependencies": {
        "pg": "^8.14.1"
      },
      "devDependencies": {
        "@types/pg": "^8.11.11"
      }
    }
  }
}
